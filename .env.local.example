# Copy to .env.local for local dev, and add the same two variables in
# Vercel (Settings -> Environment Variables -> Production + Preview).
# Both are public-by-design: Next.js inlines NEXT_PUBLIC_* into the
# client bundle, and Supabase's publishable key is meant to ship to
# every visitor's browser. Row-level security on the Supabase tables
# is what actually controls who can read or write what.

NEXT_PUBLIC_SUPABASE_URL=https://fhsrpkorvuwvwacapbig.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_M55Pnntdwu0N_uE6zt61bQ_bMUA5Bl3
