{
  "cleanUrls": true,
  "trailingSlash": false,
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ] && exit 1 || exit 0",
  "headers": [
    {
      "source": "/(.*)opengraph-image",
      "headers": [{ "key": "Content-Type", "value": "image/png" }]
    },
    {
      "source": "/(.*)twitter-image",
      "headers": [{ "key": "Content-Type", "value": "image/png" }]
    }
  ]
}
